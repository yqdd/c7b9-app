<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp">

    <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_record"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:orientation="horizontal">
            <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp">
                <ImageButton
                        android:id="@+id/chat_display_prompt_audio_button"
                        android:src="@drawable/btn_record_play_small"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@color/empty" />

                <ProgressBar
                        android:id="@+id/chat_display_prompt_audio_progress"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:indeterminateTint="@color/light_red"
                        android:visibility="gone"/>

            </FrameLayout>


            <SeekBar
                    android:id="@+id/chat_display_prompt_audio_bar"
                    android:src="@drawable/btn_record_play_small"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/light_red"
                    android:progressTint="@color/light_red"
                    android:progressBackgroundTint="@color/light_red"
                    android:background="@color/empty"/>

            <TextView
                    android:id="@+id/chat_display_prompt_audio_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/light_red"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="10dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>