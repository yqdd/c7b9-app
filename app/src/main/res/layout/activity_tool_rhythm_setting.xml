<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/high_light_gray">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="节奏听辨设置"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="10dp"/>

        <ImageButton
            android:id="@+id/back"
            android:background="@drawable/img_back"
            android:backgroundTint="@color/black"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical" />

    </FrameLayout>

    <LinearLayout
        android:background="@drawable/bg_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="15dp"
        android:padding="10dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="设置播放几拍子"/>
        <RadioGroup
            android:id="@+id/radioGroupRhythm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/enable_rhythm_4"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="25dp"
                android:text="4拍子"/>
            <RadioButton
                android:id="@+id/enable_rhythm_8"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="25dp"
                android:text="8拍子"/>
        </RadioGroup>
    </LinearLayout>

    <LinearLayout
        android:background="@drawable/bg_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="15dp"
        android:padding="10dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="设置速度"/>
        <SeekBar
            android:id="@+id/speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>


    <LinearLayout
        android:background="@drawable/bg_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="15dp"
        android:padding="10dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="设置会出现的4拍子节奏型"/>
        <LinearLayout
            android:id="@+id/rhythm4_checkboxes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="一拍/两拍/二八/十六"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="三连音"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="休切/四六/三连"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="两拍节奏带休止"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="连切带休止"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="小前/后/切分"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="八休/休八(十六)"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="两拍节奏不带休止"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="连切"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="连线(暂不支持)"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:background="@drawable/bg_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="15dp"
        android:padding="10dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="设置会出现的8拍子节奏型"/>
        <LinearLayout
            android:id="@+id/rhythm8_checkboxes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="一大拍/四八八四(十六)"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="12节奏+前后切"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="12节奏+前后切+休止"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="连切+休止"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="小小前/后替换"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="12节奏"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="12节奏+休止"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="连切"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="三连音替换"/>
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="连线(暂不支持)"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>