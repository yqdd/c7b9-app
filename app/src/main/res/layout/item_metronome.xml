<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="@drawable/bg_chat"
        android:backgroundTintMode="src_over"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="5dp"
        android:orientation="vertical">
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="5dp"
            android:gravity="center"
            android:orientation="horizontal">
        <TextView
                android:id="@+id/metronome_bpm_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="速度："
                android:textSize="16sp"/>

        <LinearLayout
                android:id="@+id/metronome_bpm_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:gravity="center"
                android:layout_marginEnd="10dp">
            <ImageButton
                    android:id="@+id/metronome_speed_down"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/btn_record_play"/>
            <EditText
                    android:id="@+id/metronome_bpm"
                    android:inputType="numberDecimal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chat"
                    android:textCursorDrawable="@color/empty"
                    android:imeOptions="actionDone"
                    android:paddingVertical="6dp"
                    android:textAlignment="center"
                    android:text="100"
                    android:textSize="16sp"/>
            <ImageButton
                    android:id="@+id/metronome_speed_up"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/btn_record_play"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
            android:id="@+id/metronome_beat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="7dp"
            android:gravity="center"
            android:orientation="horizontal">
        <EditText
                android:id="@+id/metronome_beat_n1"
                android:inputType="numberDecimal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:padding="3dp"
                android:background="@drawable/bg_chat"
                android:textCursorDrawable="@color/empty"
                android:imeOptions="actionDone"
                android:hint="几"
                android:textSize="16sp"
                android:textAlignment="center" />
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:layout_gravity="center"
                android:text="对"
                android:textSize="16sp"/>
        <EditText
                android:id="@+id/metronome_beat_n2"
                android:inputType="numberDecimal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:padding="3dp"
                android:background="@drawable/bg_chat"
                android:textCursorDrawable="@color/empty"
                android:imeOptions="actionDone"
                android:hint="几"
                android:textSize="16sp"
                android:textAlignment="center" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:id="@+id/metronome_play"
            android:background="@drawable/bg_chat"
            android:backgroundTint="@color/black"
            android:backgroundTintMode="src_over"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="5dp"
            android:paddingVertical="5dp"
            android:gravity="center"
            android:textSize="25dp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="开始"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:id="@+id/metronome_play_left"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.5"
                android:background="@color/white"
                android:visibility="invisible"/>
            <View
                android:id="@+id/metronome_play_right"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.5"
                android:background="@color/white"
                android:visibility="invisible"/>

        </LinearLayout>


    </FrameLayout>

</LinearLayout>