<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popupmenu"
        android:orientation="vertical">

    <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="无法连接到服务器"
            android:textSize="18dp"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:src="@drawable/img_server_dead" />

    <!--
    <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="建议加qq：xxxxxxx\n或者加qq群：xxxxxxxx 了解情况"
            android:textSize="14dp"/>-->


    <TextView
            android:id="@+id/server_dead_ok"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_margin="10dp"
            android:gravity="center"
            android:background="@drawable/bg_chat"
            android:backgroundTint="@color/high_light_gray"
            android:backgroundTintMode="src_over"
            android:text="确定" />

</LinearLayout>