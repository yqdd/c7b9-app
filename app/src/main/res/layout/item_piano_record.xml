<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/piano_record_layout"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:orientation="horizontal"
        android:padding="2dp"
        android:gravity="center_vertical">

    <ImageButton
            android:src="@drawable/btn_piano_delete"
            android:id="@+id/piano_delete_button"
            app:tint="@color/gray"
            android:background="@color/empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"/>

    <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingHorizontal="10dp"
            android:scrollbars="none">
        <TextView
                android:id="@+id/piano_record_name"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Record Name"
                android:textSize="18sp" />
    </HorizontalScrollView>


    <ImageButton
            android:src="@drawable/btn_piano_play"
            android:id="@+id/piano_play_button"
            app:tint="@color/gray"
            android:background="@color/empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"/>
    <ImageButton
            android:src="@drawable/btn_piano_upload"
            android:id="@+id/piano_upload_button"
            app:tint="@color/gray"
            android:background="@color/empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"/>

</LinearLayout>